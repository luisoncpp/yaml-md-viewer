{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YAML Markdown Viewer",
  "version": "0.1.0",
  "identifier": "com.luisoncpp.yamlmdviewer",
  "build": { "beforeDevCommand": "npm.cmd run dev", "beforeBuildCommand": "npm.cmd run build", "devUrl": "http://localhost:1420", "frontendDist": "../dist" },
  "app": { "windows": [{ "title": "YAML Markdown Viewer", "width": 1100, "height": 760, "resizable": true }], "security": { "csp": "default-src 'self'; style-src 'self'; script-src 'self'; img-src 'self' data:; connect-src 'none'; object-src 'none'; base-uri 'none'; form-action 'none'; frame-src 'none'" } },
  "bundle": { "active": false, "icon": ["icons/icon.ico"] }
}
